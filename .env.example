# ============================================================
# 환경 변수 설정 파일
# ============================================================
# 이 파일을 복사해서 .env 로 만들고 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================

# ── Firebase ──
# Firebase Console > Project Settings > General > Your apps
VITE_FIREBASE_API_KEY=YOUR_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=proposal-master-8eab7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=proposal-master-8eab7
VITE_FIREBASE_STORAGE_BUCKET=proposal-master-8eab7.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# ── PayPal ──
# https://developer.paypal.com/dashboard → Apps & Credentials
# Sandbox (테스트): sb-xxxx 형태
# Live (실서비스): Axxxx 형태
VITE_PAYPAL_CLIENT_ID=test
